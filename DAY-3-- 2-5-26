// Problem1
// Print 1 to 10 using a for loop

#include <iostream>
using namespace std;

int main(){
    
    for(int i = 1; i<=10; i++){
        cout << i << "\n";
        
    }
    return 0;
}

//Problem 2--
// Print reverse 1 to 10 using a for loop

#include <iostream>
using namespace std;

int main(){
    
    for(int i = 10; i >= 1; i--){
        cout << i << "\n";
        
    }
    return 0;
}



   }



//Problem 9 -- Prime Number Checker

#include <iostream>
using namespace std;
 
  int main(){
      int n;
      cout << "Enter a Number: ";
      cin >> n;
      bool isPrime = true;
      if(n < 2){
            isPrime = false;
      }else {
          for(int i = 2; i < n; i++){
              if(n % i ==0){
                  isPrime = false;
                  break;
              }
          }
      }
        if(isPrime){
            cout << n <<" is a Prime Number";
        }else{
            cout << n << " is Not a prime Number";
        }
        return 0;
}



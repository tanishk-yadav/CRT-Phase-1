//Problem -- 1
// Pattern Printing upper Right angle triangle and its opposite

#include <iostream>
using namespace std;

int main()
{
 int n;
 cout << "Enter the random num: ";
 cin >> n;

 for(int i = 1; i <= n; i++){
    //  cout << " ";
     for(int j = 1; j <= i; j++){
         cout <<"* " ;
     }
      cout << endl;
 }
 for(int k = n - 1; k >= 1; k--){

             for(int l = k ; l >= 1; l--){
             cout <<"* ";
             
         }
         cout << endl;
             
         }
    return 0;
}




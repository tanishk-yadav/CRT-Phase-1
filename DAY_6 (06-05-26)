//Problem--1
//Swapping of values of 2 variables using swap f

#include<iostream>
using namespace std;
   
    void swapNumber(int* x, int* y){
        int temp = *x;
        *x  = *y;
        *y = temp;
        
    }
    int main(){

    int a;
    int b;
    cout << "Enter the value of a:  ";
    cin>>a;
        cout << "Enter the value of b:  ";

    cin >>b;
    swapNumber(&a, &b);
    cout << "After swap the value of a is : " << a << "\n" << "After swap the value of b is : " << b;
}



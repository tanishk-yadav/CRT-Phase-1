//Problem--3
//call by value //call by refrence
//call by value -- Photocopy
//call by refrence -- original value

#include<iostream>
using namespace std;

void updatebyValue(int a){
    a = 500;
}

void updatebyRefrence(int &a){
    a = 200;
}

int main(){
    int original = 100;
        cout << original <<endl;

    
    updatebyValue(original);
    cout << original<<endl;
    
    updatebyRefrence(original);
    cout << original;
    
}



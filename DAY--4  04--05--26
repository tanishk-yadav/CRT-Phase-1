// Problem 1
//pattern 1 to 10 10 times
#include <iostream>
using namespace std;
int main()
{
  
    for(int i = 1; i <= 10; i++)
    {
        // this define what to print in the print
        for(int j = 1; j <= 10; j++){
            cout << j;
        }
        cout << endl;
    }
    
     return 0;
}


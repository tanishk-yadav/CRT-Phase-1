// Problem 4
// Print mirror of  right angled triangle
#include <iostream>
using namespace std;
int main(){
     int n;
    cout << "Enter the number: ";
    cin >> n;
  // number of times to print the pattern
    for(int i = 1; i <= n; i++)
    {
        for(int k = n - i; k >= 0; k--){
            cout<< " ";
        }
        // this define what to print in the print
        for(int j = 1; j <= i; j++){
            cout << "*";
        }
        cout << endl;
    }
    
     return 0;
}



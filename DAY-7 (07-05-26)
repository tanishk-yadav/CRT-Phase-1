//Pillar of oops
// Encapsulation

#include <iostream>
using namespace std;

class bankAccount{
    private:
    int balance;
    
    public:
    void setBalance(int amount){
        if(amount >= 0){
            balance = amount;
        }else{
            cout << "Enter a valid number....";
        }
    }
    
    
    
    public:
    int getbalance() {
        return balance;
    }
};


int main() {
    bankAccount obj1;
    obj1.setBalance(5000);
   cout <<  obj1.getbalance();
}


